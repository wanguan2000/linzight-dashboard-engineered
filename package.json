{
  "name": "linzight-dashboard-engineered",
  "private": true,
  "version": "0.0.1-beta.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "export:html": "npm run build && node scripts/export-html-pages.mjs",
    "export:openapi": "node scripts/export-openapi.mjs",
    "smoke:api": "node scripts/api-smoke.mjs",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "smoke:docker": "node scripts/docker-smoke.mjs",
    "regression:browser": "node scripts/playwright-regression.mjs",
    "release:check": "node scripts/release-check.mjs",
    "backup:sqlite": "node scripts/backup-sqlite.mjs",
    "restore:sqlite": "node scripts/restore-sqlite.mjs",
    "export:postgres-migration": "node scripts/sqlite-to-postgres-export.mjs",
    "test": "npm run smoke:api && npm run export:openapi && npm run export:html && npm run smoke:ui && npm run release:check",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint src scripts --report-unused-disable-directives --max-warnings 0",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "@eslint/js": "latest"
  }
}
