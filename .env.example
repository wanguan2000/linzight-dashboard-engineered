# Frontend API base URL.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend runtime settings. Copy backend/.env.example to backend/.env if needed.
DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
# Do not set this for formal runtime. Use only for isolated smoke/legacy SQLite tools.
# LINZIGHT_ALLOW_SQLITE_RUNTIME=1
LINZIGHT_UPLOADS_DIR=./uploads
LINZIGHT_INITIAL_ADMIN_EMAIL=guan.wang@linzight.com
LINZIGHT_INITIAL_ADMIN_PASSWORD=change-me
LINZIGHT_PUBLIC_APP_URL=http://127.0.0.1:5173
LINZIGHT_SMTP_HOST=smtp.feishu.cn
LINZIGHT_SMTP_PORT=465
LINZIGHT_SMTP_SECURITY=ssl
LINZIGHT_SMTP_USERNAME=rws@linzight.com
