# Frontend API base URL. Leave empty to let the app try the local demo API ports.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend demo settings. Copy backend/.env.example to backend/.env if needed.
DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_UPLOADS_DIR=./uploads
