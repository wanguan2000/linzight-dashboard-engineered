# Backend demo settings only. Do not put real secrets in this file.
# Runtime reads DATABASE_URL first, then LINZIGHT_DATABASE_URL.
DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_DATABASE_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_POSTGRES_URL=postgresql+psycopg2:///linzight_dashboard_engineered
LINZIGHT_UPLOADS_DIR=./uploads
